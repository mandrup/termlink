{
  "name": "termlink",
  "version": "1.1.0",
  "description": "A terminal UI for managing RDP and SSH connections",
  "license": "MIT",
  "type": "module",
  "bin": {
    "termlink": "./dist/index.js",
    "termlink-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc --noEmit && node scripts/build.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "format": "prettier --write .",
    "postinstall": "node scripts/fix-node-pty-permissions.js"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "ink": "^7.1.0",
    "ink-testing-library": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
